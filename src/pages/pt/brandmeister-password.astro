---
import Layout from '@/src/layouts/Layout.astro';
import SiteNav from '@/src/components/SiteNav.astro';
import Footer from '@/src/components/Footer.astro';
import AlertCircle from '@/src/components/icons/AlertCircle.astro';
import LifeBuoy from '@/src/components/icons/LifeBuoy.astro';
import { localeFromUrl } from '@/src/i18n/routing';
import { t } from '@/src/i18n/t';

const pathname = Astro.url.pathname;
const lang = localeFromUrl(pathname);

const title = `${t('bmpw.metaTitle', lang)} — VoxDMR`;
const description = t('bmpw.metaDescription', lang);

const stepHrefs: Record<number, string> = {
  2: t('bmpw.step2.href', lang),
};

const steps = [1, 2, 3, 4].map((n) => ({
  n,
  title: t(`bmpw.step${n}.title`, lang),
  body: t(`bmpw.step${n}.body`, lang),
  href: stepHrefs[n],
}));

// Split the intro so the key phrase can be emphasized.
const highlight = t('bmpw.introHighlight', lang);
const [introBefore, introAfter] = t('bmpw.intro', lang).split(highlight);
---

<Layout lang={lang} title={title} description={description} pathname={pathname}>
  <div class="min-h-screen bg-community-bg text-on-surface font-sans">
    <SiteNav lang={lang} pathname={pathname} />

    <main class="max-w-3xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-vibrant-red mb-4">
        {t('bmpw.eyebrow', lang)}
      </p>
      <h1 class="text-4xl lg:text-5xl font-headline font-bold text-white mb-5 tracking-tight">
        {t('bmpw.title', lang)}
      </h1>
      <p class="text-lg lg:text-xl text-on-surface-muted leading-relaxed max-w-[60ch] mb-10">
        {introBefore}<strong class="text-white font-semibold">{highlight}</strong>{introAfter}
      </p>

      <!-- Warning callout -->
      <div class="flex gap-4 rounded-2xl bg-vibrant-red/[0.08] border border-vibrant-red/40 px-6 py-5 mb-12">
        <AlertCircle class="w-6 h-6 text-vibrant-red shrink-0 mt-0.5" />
        <div class="leading-relaxed">
          <p class="font-bold text-white mb-1">{t('bmpw.warn.title', lang)}</p>
          <p class="text-on-surface-muted">{t('bmpw.warn.body', lang)}</p>
        </div>
      </div>

      <!-- Steps -->
      <h2 class="text-2xl lg:text-3xl font-headline font-bold text-white mb-7 tracking-tight">
        {t('bmpw.stepsTitle', lang)}
      </h2>
      <div class="flex flex-col mb-14">
        {steps.map((step) => (
          <div class="flex gap-5 py-5 border-b border-border">
            <span class="shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-surface-raised border border-white/10 font-mono font-bold text-vibrant-blue">
              {step.n}
            </span>
            <div class="pt-1">
              <p class="text-lg font-semibold text-white mb-1.5">{step.title}</p>
              <p class="text-on-surface-muted leading-relaxed">{step.body}</p>
              {step.href && (
                <a
                  href={step.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block mt-2 font-mono text-sm text-vibrant-blue hover:underline break-all"
                >
                  {step.href}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Enter it in VoxDMR -->
      <h2 class="text-2xl lg:text-3xl font-headline font-bold text-white mb-5 tracking-tight">
        {t('bmpw.enterTitle', lang)}
      </h2>
      <p class="text-on-surface-muted leading-relaxed mb-4">{t('bmpw.enterBody', lang)}</p>
      <p class="font-mono text-sm text-on-surface-muted mb-8">{t('bmpw.statusFlow', lang)}</p>

      <!-- Mock profile field -->
      <div class="rounded-3xl bg-surface-raised/40 border border-white/[0.07] p-6 mb-12">
        <div class="flex items-center gap-2.5 mb-5">
          <span class="inline-flex items-center rounded-full bg-vibrant-red/15 text-vibrant-red text-xs font-bold uppercase tracking-wider px-3 py-1">
            BrandMeister
          </span>
          <span class="text-sm text-on-surface-muted">{t('bmpw.mock.addProfile', lang)}</span>
        </div>

        <label class="block text-xs font-bold uppercase tracking-[0.18em] text-on-surface-muted mb-2">
          {t('bmpw.mock.dmrId', lang)}
        </label>
        <div class="flex items-center px-4 py-3 rounded-xl bg-surface-raised border border-white/[0.07] font-mono text-on-surface mb-5">
          2680513
        </div>

        <label class="block text-xs font-bold uppercase tracking-[0.18em] text-on-surface-muted mb-2">
          {t('bmpw.mock.password', lang)}
        </label>
        <div class="flex items-center px-4 py-3 rounded-xl bg-surface-raised border border-vibrant-blue font-mono text-on-surface tracking-[0.2em]">
          ••••••••••••
        </div>
      </div>

      <!-- Troubleshooting -->
      <div class="flex gap-4 rounded-2xl bg-vibrant-blue/[0.06] border border-vibrant-blue/35 px-6 py-5">
        <LifeBuoy class="w-6 h-6 text-vibrant-blue shrink-0 mt-0.5" />
        <div class="leading-relaxed">
          <p class="font-bold text-white mb-1">{t('bmpw.trouble.title', lang)}</p>
          <p class="text-on-surface-muted">
            {t('bmpw.trouble.body', lang).split(t('bmpw.trouble.selfcare', lang)).flatMap((part, i) =>
              i === 0
                ? [part]
                : [
                    <a
                      href="https://brandmeister.network/"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-vibrant-blue hover:underline"
                    >{t('bmpw.trouble.selfcare', lang)}</a>,
                    part,
                  ]
            )}
          </p>
        </div>
      </div>
    </main>

    <Footer lang={lang} />
  </div>
</Layout>
